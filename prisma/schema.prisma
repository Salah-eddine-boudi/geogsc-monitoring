generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────

enum Role {
  BRIGADE
  IGT
  ADMIN
}

enum ZoneGSC {
  A
  B
  C
  D
  HORS_ZONE
}

enum ConditionMeteo {
  BEAU
  NUAGEUX
  PLUIE
  VENT_FORT
  BROUILLARD
}

enum StatutConformite {
  CONFORME
  NON_CONFORME
  RESERVE
}

// ── NatureIntervention — 16 valeurs CDC §3.1.2 ────────────────────
enum NatureIntervention {
  // Nouvelles — CDC §3.1.2 (ordre logique terrain)
  IMPLANTATION
  CONTROLE_IMPLANTATION
  CONTROLE_COFFRAGE
  CONTROLE_VERTICALITE
  CONTROLE_NIVELLEMENT
  CONTROLE_PLANEITE
  RECEPTION_AVANT_BETONNAGE
  RECEPTION_APRES_BETONNAGE
  RECEPTION_APRES_DECOFFRAGE
  CONTROLE_FOND_FOUILLE
  CONTROLE_FIL_EAU
  CONTROLE_COTE_RADIER
  LEVE_CONTRADICTOIRE
  LEVE_AS_BUILT
  CONTROLE_PENTE
  AUTRE
  // Anciens — compatibilité
  CONTROLE_GEOMETRIQUE
  CONTROLE_ALTIMETRIQUE
  CONTROLE_NIVELLEMNT    // typo gardée pour compatibilité BDD
  RECEPTION
  RELEVE_TOPOGRAPHIQUE
  PIQUETAGE
  CONTRADICTOIRE
}

// ── StadeCollage — CDC §3.1.2 ─────────────────────────────────────
enum StadeCollage {
  // Nouveaux — CDC
  PREMIER_COLLAGE
  DEUXIEME_COLLAGE
  TROISIEME_COLLAGE
  PREMIERE_LEVEE
  DEUXIEME_LEVEE
  TROISIEME_LEVEE
  LEVEE_FINALE
  NA
  // Anciens — compatibilité
  AVANT_BETONNAGE
  APRES_BETONNAGE
  AVANT_SOUDURE
  APRES_SOUDURE
  RECEPTION_FINALE
}

// ── ProvenanceAppareil — Q5 chantier ─────────────────────────────
enum ProvenanceAppareil {
  GEOCODING    // Matériel GEOCODING (interne)
  ENTREPRISE   // Matériel Entreprise (externe)
}

// ── ProvenanceMateriel — Q5 chantier ─────────────────────────────
enum ProvenanceMateriel {
  GEOCODING
  ENTREPRISE
}

// ── AppareilMesure — gardé pour compatibilité données existantes ──
enum AppareilMesure {
  TRIMBLE_SX12
  TRIMBLE_S7
  LEICA_TS16
  LEICA_NA730
  GPS_TRIMBLE
  NIVEAU_OPTIQUE
  AUTRE
}

enum StatutFiche {
  BROUILLON
  SOUMISE
  VALIDEE
  REJETEE
}

enum StatutMission {
  PLANIFIEE
  EN_COURS
  TERMINEE
}

enum TypeOuvrage {
  PLATINE
  POTEAU
  POTEAU_AV_BETONNAGE
  POTEAU_AP_BETONNAGE
  POUTRE_CREMAILLERE_AV_BETONNAGE
  POUTRE_CREMAILLERE_AP_BETONNAGE
  VOILE
  VOILE_AV_BETONNAGE
  VOILE_AP_BETONNAGE
  GRADIN
  CHAMBORD
  VOMITOIRE
  SEMELLE_FILANTE
  SEMELLE_ISOLEE
  DALLES
  MUR_SOUTENEMENT
  TERRASSEMENT
  ASSAINISSEMENT
  FONDATION
  VRD
  AUTRE
  FIXATION_BOULONS_CREMAILLERES_AV_BETONNAGE
  FIXATION_BOULONS_CREMAILLERES_AP_BETONNAGE
  SUPPORT_GRADIN
  DALLES_AV_BETONNAGE
  DALLES_AP_BETONNAGE
  IMPLANTATION_GENERAL
  LIT_POSE
  COFFRAGE_VOILES_REGARD
  VOILE_REGARD_AP_BETONNAGE
  COFFRAGE_RADIER
  COFFRAGE_DALLE
  COFFRAGE_GROS_BETON
  GROS_BETON_AP_BETONNAGE
}

enum TypeControle {
  IMPLANTATION
  ALTIMETRIE
  VERTICALITY
  RECEPTION
  CONTRADICTOIRE
}

enum CategorieAssainissement {
  FOND_DE_FOUILLE
  FIL_EAU
  COTE_RADIER
  LIT_POSE
  COFFRAGE_VOILES_REGARD
  VOILE_REGARD_AP_BETONNAGE
  COFFRAGE_RADIER
  COFFRAGE_DALLE
  COFFRAGE_GROS_BETON
  GROS_BETON_AP_BETONNAGE
  IMPLANTATION_GENERAL
  AUTRE
}

enum StatutControle {
  CONFORME
  NON_CONFORME
  RESERVE
}

// ─── USER ─────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  nom           String
  prenom        String
  email         String   @unique
  password      String
  role          Role
  gsm           String?
  stationTotale String?
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brigade        Brigade?           @relation(fields: [brigadeId], references: [id])
  brigadeId      String?
  fichesCreees   FicheJournaliere[] @relation("FicheCreateur")
  fichesValidees FicheJournaliere[] @relation("FicheValidateur")
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  cpCrees        CompteRenduCP[]    @relation("CPCreateur")

  @@map("users")
}

// ─── COMPTE RENDU CP ──────────────────────────────────────────────

enum StatutCP {
  BROUILLON
  SOUMIS
  VALIDE
}

enum TypeEvenement {
  VISITE_CHANTIER
  REUNION
  INCIDENT
  CONSTAT
  AUTRE
}

enum CriticiteVigilance {
  HAUTE
  MOYENNE
  FAIBLE
}

model CompteRenduCP {
  id           String   @id @default(cuid())
  semaine      Int
  annee        Int
  statut       StatutCP @default(BROUILLON)
  observations String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt DateTime?

  brigade   Brigade @relation(fields: [brigadeId], references: [id])
  brigadeId String

  createur   User   @relation("CPCreateur", fields: [createurId], references: [id])
  createurId String

  evenements      EvenementCP[]
  pointsVigilance PointVigilanceCP[]

  @@unique([brigadeId, semaine, annee])
  @@map("comptes_rendus_cp")
}

model EvenementCP {
  id           String        @id @default(cuid())
  date         DateTime
  type         TypeEvenement
  description  String
  participants String?
  lieu         String?
  createdAt    DateTime      @default(now())

  cp   CompteRenduCP @relation(fields: [cpId], references: [id])
  cpId String

  @@map("evenements_cp")
}

model PointVigilanceCP {
  id          String             @id @default(cuid())
  criticite   CriticiteVigilance
  description String
  action      String?
  responsable String?
  echeance    DateTime?
  resolu      Boolean            @default(false)
  createdAt   DateTime           @default(now())

  cp   CompteRenduCP @relation(fields: [cpId], references: [id])
  cpId String

  @@map("points_vigilance_cp")
}

// ─── BRIGADE ──────────────────────────────────────────────────────

model Brigade {
  id        String   @id @default(cuid())
  nom       String   @unique
  chef      String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  membres         User[]
  fiches          FicheJournaliere[]
  comptesRendusCP CompteRenduCP[]

  @@map("brigades")
}

// ─── FICHE JOURNALIERE ────────────────────────────────────────────

model FicheJournaliere {
  id             String          @id @default(cuid())
  date           DateTime
  statut         StatutFiche     @default(BROUILLON)
  observations   String?
  conditionMeteo ConditionMeteo?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
@@index([deletedAt])

  brigade   Brigade @relation(fields: [brigadeId], references: [id])
  brigadeId String

  createur   User   @relation("FicheCreateur", fields: [createurId], references: [id])
  createurId String

  validateur   User?   @relation("FicheValidateur", fields: [validateurId], references: [id])
  validateurId String?

  missions Mission[]

  @@unique([brigadeId, date])
  @@map("fiches_journalieres")
}

// ─── MISSION ──────────────────────────────────────────────────────

model Mission {
  id            String        @id @default(cuid())
  statut        StatutMission @default(PLANIFIEE)
  heureDebut    DateTime?
  heureFin      DateTime?
  observations  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?     // Ajouté pour le soft-delete

  zone          ZoneGSC?
  sousZone      String?
  axe           String?
  fil           String?
  niveau        String?
  partieOuvrage String?

  nature         NatureIntervention?
  travailRealise String?
  stadeCollage   StadeCollage?

  provenanceAppareil ProvenanceAppareil?
  nomAppareil        String?
  appareil           AppareilMesure?

  provenanceMateriel ProvenanceMateriel?

  // RESULTAT EN ENUM (Corrigé)
  resultat       StatutConformite?
  ficheReference String?

  // LE CHAMP MANQUANT POUR TON SEED !
  estNC Boolean @default(false)

  typeOuvrage      TypeOuvrage?
  typeOuvrageLibre String?

  categorieAssainissement CategorieAssainissement?
  assainissementLibre     String?

  ouvrage   Ouvrage @relation(fields: [ouvrageId], references: [id])
  ouvrageId String

  fiche   FicheJournaliere @relation(fields: [ficheId], references: [id])
  ficheId String

  controles Controle[]
  photos    Photo[] // LA RELATION MANQUANTE POUR TON SEED !

  @@index([estNC])
  @@index([deletedAt])
  @@map("missions")
}

// ─── OUVRAGE ──────────────────────────────────────────────────────

model Ouvrage {
  id          String      @id @default(cuid())
  reference   String      @unique
  designation String
  type        TypeOuvrage
  axe         String?
  niveau      String?
  actif       Boolean     @default(true)
  createdAt   DateTime    @default(now())

  missions Mission[]

  @@map("ouvrages")
}

// ─── CONTROLE ─────────────────────────────────────────────────────

model Controle {
  id           String         @id @default(cuid())
  type         TypeControle
  statut       StatutControle
  ecartX       Float?
  ecartY       Float?
  ecartZ       Float?
  toleranceX   Float?
  toleranceY   Float?
  toleranceZ   Float?
  observations String?
  createdAt    DateTime       @default(now())

  mission   Mission @relation(fields: [missionId], references: [id])
  missionId String

  @@map("controles")
}

// ─── REFRESH TOKEN ────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entite    String
  entiteId  String
  userId    String
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entiteId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── PHOTO ────────────────────────────────────────────────────────

model Photo {
  id        String   @id @default(cuid())
  url       String
  latitude  Float?
  longitude Float?
  legende   String?
  taille    Int?
  createdAt DateTime @default(now())

  mission   Mission @relation(fields: [missionId], references: [id])
  missionId String

  @@index([missionId])
  @@map("photos")
}